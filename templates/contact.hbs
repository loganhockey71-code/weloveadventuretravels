<!DOCTYPE html>
<html lang="en">
<head>
  {{> head meta=meta}}
</head>
<body>

{{> topbar shared=shared}}
{{> nav activePage=activePage}}

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-hero-bg" style="background-image:url('{{pageHero.backgroundImage}}')"></div>
  <div class="page-hero-content">
    <span class="ph-sub">{{pageHero.sub}}</span>
    <h1>{{pageHero.title}}</h1>
    <p>{{pageHero.description}}</p>
  </div>
</section>

<!-- MAIN CONTACT SECTION -->
<section class="section" id="quote">
  <div class="section-inner">
    <div class="contact-grid">

      <!-- LEFT: Victoria's info -->
      <div class="contact-info reveal">
        <h2>{{intro.heading}}</h2>
        <p>{{intro.paragraph}}</p>

        <div class="contact-details">
          <div class="contact-detail">
            <div class="contact-icon" style="background:rgba(232,84,32,.1)">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <div>
              <span class="contact-label">Phone</span>
              <div class="contact-value"><a href="tel:{{shared.phoneHref}}">{{shared.phone}}</a></div>
            </div>
          </div>
          <div class="contact-detail">
            <div class="contact-icon" style="background:rgba(24,104,196,.1)">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="contact-label">Email</span>
              <div class="contact-value"><a href="mailto:{{shared.email}}">{{shared.email}}</a></div>
            </div>
          </div>
          <div class="contact-detail">
            <div class="contact-icon" style="background:rgba(56,168,50,.1)">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </div>
            <div>
              <span class="contact-label">Instagram</span>
              <div class="contact-value">
                <a href="{{shared.instagramUrl}}" target="_blank" rel="noopener">{{shared.instagramHandle}}</a>
              </div>
            </div>
          </div>
          <div class="contact-detail">
            <div class="contact-icon" style="background:rgba(124,63,160,.1)">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--purple)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <span class="contact-label">Response Time</span>
              <div class="contact-value">Within 24 hours</div>
            </div>
          </div>
        </div>

        <!-- Image -->
        <div style="border-radius:8px;overflow:hidden;margin-top:.5rem">
          <img src="{{sideImage}}" alt="Beautiful travel destination" loading="lazy" style="width:100%;height:240px;object-fit:cover">
        </div>

        <div style="margin-top:1.5rem;padding:1.5rem;background:var(--off-white);border-radius:8px;border-left:3px solid var(--orange)">
          <p style="font-weight:700;margin-bottom:.4rem;color:var(--text)">{{freeNote.heading}}</p>
          <p style="font-size:.875rem;color:var(--text-muted);line-height:1.65">{{freeNote.text}}</p>
        </div>
      </div>

      <!-- RIGHT: Form -->
      <div class="reveal reveal-d1">
        <div style="background:var(--off-white);padding:2.5rem;border-radius:8px;border:1px solid var(--border)">
          <h3 style="font-family:'Pacifico',cursive;font-size:clamp(1.4rem,3vw,1.9rem);color:var(--text);margin-bottom:1.75rem">{{formHeading}}</h3>
          <form action="https://formsubmit.co/{{shared.email}}" method="POST">
            <input type="text" name="_honey" class="honeypot" tabindex="-1" autocomplete="off">
            <input type="hidden" name="_subject" value="New Vacation Inquiry — We Love Adventure Travels">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_next" value="thank-you.html">
            <div class="form-grid">
              <div class="form-group">
                <label for="c-name">Full Name <span class="req">*</span></label>
                <input type="text" id="c-name" name="name" placeholder="Jane Smith" required>
              </div>
              <div class="form-group">
                <label for="c-email">Email Address <span class="req">*</span></label>
                <input type="email" id="c-email" name="email" placeholder="you@example.com" required>
              </div>
              <div class="form-group">
                <label for="c-phone">Phone Number <span class="req">*</span></label>
                <input type="tel" id="c-phone" name="phone" placeholder="(555) 000-0000" required>
              </div>
              <div class="form-group">
                <label for="c-contact-time">Best Time to Reach You</label>
                <select id="c-contact-time" name="best_time">
                  <option value="">Select</option>
                  <option>Morning (8am–12pm)</option>
                  <option>Afternoon (12pm–5pm)</option>
                  <option>Evening (5pm–8pm)</option>
                  <option>Anytime</option>
                </select>
              </div>
              <div class="form-group">
                <label for="c-destination">Type of Trip <span class="req">*</span></label>
                <select id="c-destination" name="trip_type" required>
                  <option value="">Select</option>
                  <option>Cruise</option>
                  <option>All-Inclusive Resort</option>
                  <option>Disney World</option>
                  <option>Disneyland</option>
                  <option>Universal Studios</option>
                  <option>Europe</option>
                  <option>Caribbean</option>
                  <option>Mexico</option>
                  <option>Honeymoon</option>
                  <option>Group / Family Reunion</option>
                  <option>Not sure yet — need advice</option>
                </select>
              </div>
              <div class="form-group">
                <label for="c-dates">Approximate Travel Dates</label>
                <input type="text" id="c-dates" name="travel_dates" placeholder="e.g. Spring 2026">
              </div>
              <div class="form-group">
                <label for="c-travelers">Number of Travelers</label>
                <select id="c-travelers" name="travelers">
                  <option value="">Select</option>
                  <option>1</option>
                  <option>2</option>
                  <option>3–4</option>
                  <option>5–8</option>
                  <option>9–15</option>
                  <option>16+</option>
                </select>
              </div>
              <div class="form-group">
                <label for="c-budget">Budget Per Person</label>
                <select id="c-budget" name="budget">
                  <option value="">Select</option>
                  <option>Under $1,000</option>
                  <option>$1,000–$2,500</option>
                  <option>$2,500–$5,000</option>
                  <option>$5,000–$10,000</option>
                  <option>$10,000+</option>
                  <option>Flexible</option>
                </select>
              </div>
              <div class="form-group full">
                <label for="c-notes">Anything Else Victoria Should Know?</label>
                <textarea id="c-notes" name="message" placeholder="Tell her about your must-haves, travel style, past trips you loved, or any special occasions you're celebrating!"></textarea>
              </div>
            </div>
            <div style="margin-top:1.25rem">
              <button type="submit" class="btn btn-orange" style="width:100%;justify-content:center;font-size:1rem;padding:1rem 1.5rem">
                ✈ Send My Request to Victoria
              </button>
              <p style="font-size:.78rem;color:var(--text-muted);text-align:center;margin-top:.75rem">Victoria will respond within 24 hours. No spam, no pressure.</p>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- TESTIMONIAL STRIP -->
<section style="background:var(--off-white);padding:3rem 1.5rem;border-top:1px solid var(--border)">
  <div style="max-width:1280px;margin:0 auto;text-align:center">
    <p class="reveal" style="font-family:'Pacifico',cursive;font-size:clamp(1.1rem,2.5vw,1.6rem);color:var(--text);margin-bottom:1.5rem">"{{testimonial.text}}"</p>
    <span class="reveal reveal-d1" style="font-family:'Pacifico',cursive;color:var(--orange);font-size:.95rem">{{testimonial.author}}</span>
  </div>
</section>

{{> footer shared=shared isHome=false}}

<script src="js/main.js"></script>
</body>
</html>
