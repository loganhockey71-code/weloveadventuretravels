<!DOCTYPE html>
<html lang="en">
<head>
  {{> head meta=meta}}
</head>
<body>

{{> topbar shared=shared}}
{{> nav activePage=activePage}}

<!-- HERO -->
<section class="hero" aria-label="Hero banner">
  <div class="hero-bg" style="background-image:url('{{hero.backgroundImage}}')"></div>
  <div class="hero-content">
    <span class="hero-eyebrow">{{hero.eyebrow}}</span>
    <h1 class="hero-title">{{hero.title}}</h1>
    <span class="hero-subtitle">{{hero.subtitle}}</span>
    <p class="hero-desc">{{hero.description}}</p>
    <div class="hero-ctas">
      <a href="contact.html" class="btn btn-orange">{{hero.ctaPrimaryText}}</a>
      <a href="contact.html" class="btn btn-white-outline">{{hero.ctaSecondaryText}}</a>
    </div>
  </div>
</section>

<!-- STATS STRIP -->
<div class="stats-strip">
  <div class="stats-strip-inner">
    {{#each stats}}
    <div class="stat-item reveal{{#if @index}} reveal-d{{@index}}{{/if}}">
      <span class="stat-num">{{num}}</span>
      <span class="stat-label">{{label}}</span>
    </div>
    {{/each}}
  </div>
</div>

<!-- MEET VICTORIA -->
<section class="section">
  <div class="section-inner">
    <div class="meet-grid">
      <div class="meet-img-wrap reveal">
        <img src="{{meet.image}}" alt="Beautiful travel destination planned by Victoria Smith" loading="lazy">
        <div class="meet-img-accent" aria-hidden="true"></div>
      </div>
      <div class="meet-text reveal reveal-d1">
        <span class="eyebrow" style="color:var(--green)">{{meet.eyebrow}}</span>
        <h2>{{meet.heading}}</h2>
        <p>{{meet.paragraph1}}</p>
        <p>{{meet.paragraph2}}</p>
        <div class="meet-points">
          {{#each meet.points}}
          <div class="meet-point">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--{{color}})" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {{text}}
          </div>
          {{/each}}
        </div>
        <a href="contact.html" class="btn btn-orange">Book a Free Consultation</a>
      </div>
    </div>
  </div>
</section>

<!-- POPULAR WAYS TO TRAVEL -->
<section class="section section-bg">
  <div class="section-inner">
    <div class="section-header">
      <span class="eyebrow reveal" style="color:var(--blue)">Find Your Next Adventure</span>
      <h2 class="reveal reveal-d1">Popular Ways to Travel</h2>
      <span class="divider d-green reveal reveal-d1"></span>
      <p class="section-sub reveal reveal-d2">From the open ocean to the magic of Disney, Victoria works with the best travel partners to get you the trip you've always dreamed of — at the best possible value.</p>
    </div>
    <div class="travel-grid">
      {{#each travelCards}}
      <article class="travel-card reveal{{#if @index}} reveal-d{{@index}}{{/if}}">
        <div class="travel-card-img">
          <img src="{{image}}" alt="{{title}}" loading="lazy">
        </div>
        <div class="travel-card-badge" aria-hidden="true" style="background:var(--{{color}})">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{{icon}}}</svg>
        </div>
        <div class="travel-card-body">
          <h3 style="color:var(--{{color}})">{{title}}</h3>
          <p>{{description}}</p>
          <a href="{{link}}" class="travel-card-link" style="color:var(--{{color}})">{{linkText}}</a>
        </div>
      </article>
      {{/each}}
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<section class="section">
  <div class="section-inner">
    <div class="section-header">
      <span class="eyebrow reveal" style="color:var(--orange)">Client Stories</span>
      <h2 class="reveal reveal-d1">What Our Clients Are Saying</h2>
      <span class="divider d-orange reveal reveal-d1"></span>
    </div>
    <div class="testi-grid">
      {{#each testimonials}}
      <article class="testi-card reveal{{#if @index}} reveal-d{{@index}}{{/if}}">
        <p class="testi-text">"{{text}}"</p>
        <span class="testi-author">{{author}}</span>
      </article>
      {{/each}}
    </div>
  </div>
</section>

<!-- GET A QUOTE SPLIT -->
<div class="quote-split" id="quote">
  <div class="quote-left">
    <div class="quote-left-bg" style="background-image:url('{{quoteSplit.backgroundImage}}')"></div>
    <div class="quote-left-text reveal">
      <h2>{{quoteSplit.heading}}</h2>
      <p>{{quoteSplit.paragraph}}</p>
      <div style="display:flex;flex-direction:column;gap:.75rem;">
        <a href="tel:{{shared.phoneHref}}" class="btn btn-orange" style="width:fit-content">📞 Call {{shared.phone}}</a>
        <a href="mailto:{{shared.email}}" class="btn btn-white-outline" style="width:fit-content">✉ Send an Email</a>
      </div>
    </div>
  </div>
  <div class="quote-right reveal">
    <h3>Get a Free Vacation Quote</h3>
    <form action="https://formsubmit.co/{{shared.email}}" method="POST">
      <input type="text" name="_honey" class="honeypot" tabindex="-1" autocomplete="off">
      <input type="hidden" name="_subject" value="New Vacation Quote Request — We Love Adventure Travels">
      <input type="hidden" name="_captcha" value="false">
      <div class="form-grid">
        <div class="form-group">
          <label for="name">Full Name <span class="req">*</span></label>
          <input type="text" id="name" name="name" placeholder="Jane Smith" required>
        </div>
        <div class="form-group">
          <label for="email">Email Address <span class="req">*</span></label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
        </div>
        <div class="form-group">
          <label for="phone">Phone Number <span class="req">*</span></label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" required>
        </div>
        <div class="form-group">
          <label for="best-time">Best Time to Contact</label>
          <select id="best-time" name="best_time">
            <option value="">Select</option>
            <option>Morning (8am–12pm)</option>
            <option>Afternoon (12pm–5pm)</option>
            <option>Evening (5pm–8pm)</option>
            <option>Anytime</option>
          </select>
        </div>
        <div class="form-group">
          <label for="destination">Destination Interest <span class="req">*</span></label>
          <select id="destination" name="destination" required>
            <option value="">Select a destination type</option>
            <option>Cruise</option>
            <option>All-Inclusive Resort</option>
            <option>Disney World</option>
            <option>Disneyland</option>
            <option>Universal Studios</option>
            <option>Europe</option>
            <option>Caribbean</option>
            <option>Mexico</option>
            <option>Not sure yet</option>
          </select>
        </div>
        <div class="form-group">
          <label for="travel-dates">Approximate Travel Dates</label>
          <input type="text" id="travel-dates" name="travel_dates" placeholder="e.g. March 2026">
        </div>
        <div class="form-group">
          <label for="travelers">Number of Travelers</label>
          <select id="travelers" name="travelers">
            <option value="">Select</option>
            <option>1</option>
            <option>2</option>
            <option>3–4</option>
            <option>5–8</option>
            <option>9+</option>
          </select>
        </div>
        <div class="form-group">
          <label for="budget">Budget Range (per person)</label>
          <select id="budget" name="budget">
            <option value="">Select</option>
            <option>Under $1,000</option>
            <option>$1,000–$2,500</option>
            <option>$2,500–$5,000</option>
            <option>$5,000+</option>
            <option>Flexible</option>
          </select>
        </div>
        <div class="form-group full">
          <label for="notes">Tell Victoria About Your Dream Trip</label>
          <textarea id="notes" name="notes" placeholder="Share any ideas, must-haves, or questions — the more detail the better!"></textarea>
        </div>
      </div>
      <div style="margin-top:1rem">
        <button type="submit" class="btn btn-orange" style="width:100%;justify-content:center;font-size:1rem;padding:1rem">
          ✈ Send My Request
        </button>
      </div>
    </form>
  </div>
</div>

{{> footer shared=shared isHome=true}}

<script src="js/main.js"></script>
</body>
</html>
